<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Verbes Irréguliers 🇬🇧</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#080810;--surf:#12121e;--surf2:#1a1a2e;--bord:#252538;
  --c1:#ff6b35;--c2:#7c4dff;--c3:#00e5a0;--c4:#ffd600;
  --c5:#ff4081;--c6:#00b4d8;--c7:#f72585;--c8:#b5e853;
  --tx:#f0f0f8;--dim:#6a6a8a;
  --fh:'Syne',sans-serif;--fm:'Space Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--tx);font-family:var(--fh);min-height:100vh;overflow-x:hidden;}
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 80% 50% at 20% 0%,rgba(124,77,255,.08) 0%,transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 100%,rgba(255,107,53,.06) 0%,transparent 60%),
    linear-gradient(rgba(124,77,255,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(124,77,255,.025) 1px,transparent 1px);
  background-size:100% 100%,100% 100%,50px 50px,50px 50px;
}
.wrap{position:relative;z-index:1;max-width:1240px;margin:0 auto;padding:0 16px 60px;}

/* HEADER */
header{text-align:center;padding:clamp(36px,8vw,80px) 16px 32px;}
.eyebrow{font-family:var(--fm);font-size:10px;letter-spacing:5px;color:var(--c3);text-transform:uppercase;margin-bottom:14px;}
header h1{
  font-size:clamp(44px,10vw,96px);font-weight:800;line-height:.92;letter-spacing:-3px;
  background:linear-gradient(135deg,#fff 0%,var(--c2) 45%,var(--c1) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:16px;
}
header p{color:var(--dim);font-family:var(--fm);font-size:clamp(11px,2vw,13px);max-width:500px;margin:0 auto;line-height:1.9;}

/* FORMULA */
.formula{
  display:flex;align-items:center;justify-content:center;gap:clamp(8px,3vw,20px);
  flex-wrap:wrap;background:var(--surf);border:1px solid var(--bord);
  border-left:4px solid var(--c2);border-radius:14px;
  padding:clamp(14px,3vw,22px) clamp(16px,4vw,32px);
  margin:24px auto;max-width:680px;font-family:var(--fm);
}
.formula .step{display:flex;flex-direction:column;align-items:center;gap:4px;}
.formula .step .sv{font-size:clamp(14px,3vw,19px);font-weight:700;color:var(--c4);}
.formula .step .sl{font-size:9px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;}
.formula .arrow{font-size:clamp(18px,3vw,24px);color:var(--c2);}

/* TABS */
.tabs{
  display:flex;gap:4px;background:var(--surf);border:1px solid var(--bord);
  border-radius:16px;padding:6px;overflow-x:auto;scrollbar-width:none;
  -webkit-overflow-scrolling:touch;margin-bottom:28px;
}
.tabs::-webkit-scrollbar{display:none;}
.tab-btn{
  flex:1;min-width:90px;padding:11px 12px;background:transparent;border:none;
  border-radius:11px;color:var(--dim);font-family:var(--fh);font-size:clamp(11px,2vw,14px);
  font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap;letter-spacing:.5px;
}
.tab-btn:hover{color:var(--tx);background:var(--surf2);}
.tab-btn.active{background:var(--c2);color:#fff;}
.panel{display:none;animation:fadeIn .3s ease;}
.panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* FAMILIES */
.fgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,300px),1fr));gap:18px;}
.fcard{
  background:var(--surf);border:1px solid var(--bord);border-radius:18px;
  padding:22px;transition:transform .2s,border-color .2s,box-shadow .2s;
}
.fcard:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.35);}
.fbadge{display:inline-block;padding:5px 12px;border-radius:20px;font-family:var(--fm);font-size:10px;font-weight:700;letter-spacing:2px;margin-bottom:12px;}
.fcard h3{font-size:clamp(18px,3vw,22px);font-weight:800;margin-bottom:4px;}
.fsub{font-family:var(--fm);font-size:10px;color:var(--dim);margin-bottom:14px;letter-spacing:1px;text-transform:uppercase;}
.vlist{display:flex;flex-direction:column;gap:6px;}
.vrow{
  display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;
  padding:8px 10px;background:var(--bg);border-radius:9px;
  font-family:var(--fm);font-size:11px;border:1px solid transparent;transition:border-color .15s;
}
.vrow:hover{border-color:var(--bord);}
.v1{font-weight:700;color:var(--tx);}
.v2,.v3{color:var(--dim);}
.vmean{grid-column:1/-1;font-size:9px;color:var(--dim);font-style:italic;margin-top:2px;letter-spacing:.5px;}
.more{text-align:center;padding:7px;font-family:var(--fm);font-size:10px;color:var(--dim);}

/* family colours */
.fc1{border-color:rgba(255,107,53,.25);} .fc1:hover{border-color:var(--c1);} .fc1 h3{color:var(--c1);} .fc1 .fbadge{background:rgba(255,107,53,.12);color:var(--c1);}
.fc2{border-color:rgba(0,229,160,.25);} .fc2:hover{border-color:var(--c3);} .fc2 h3{color:var(--c3);} .fc2 .fbadge{background:rgba(0,229,160,.12);color:var(--c3);}
.fc3{border-color:rgba(255,214,0,.25);} .fc3:hover{border-color:var(--c4);} .fc3 h3{color:var(--c4);} .fc3 .fbadge{background:rgba(255,214,0,.12);color:var(--c4);}
.fc4{border-color:rgba(124,77,255,.25);} .fc4:hover{border-color:var(--c2);} .fc4 h3{color:var(--c2);} .fc4 .fbadge{background:rgba(124,77,255,.12);color:var(--c2);}
.fc5{border-color:rgba(255,64,129,.25);} .fc5:hover{border-color:var(--c5);} .fc5 h3{color:var(--c5);} .fc5 .fbadge{background:rgba(255,64,129,.12);color:var(--c5);}
.fc6{border-color:rgba(0,180,216,.25);} .fc6:hover{border-color:var(--c6);} .fc6 h3{color:var(--c6);} .fc6 .fbadge{background:rgba(0,180,216,.12);color:var(--c6);}
.fc7{border-color:rgba(247,37,133,.25);} .fc7:hover{border-color:var(--c7);} .fc7 h3{color:var(--c7);} .fc7 .fbadge{background:rgba(247,37,133,.12);color:var(--c7);}
.fc8{border-color:rgba(181,232,83,.25);} .fc8:hover{border-color:var(--c8);} .fc8 h3{color:var(--c8);} .fc8 .fbadge{background:rgba(181,232,83,.12);color:var(--c8);}
.fc9{border-color:rgba(255,255,255,.1);} .fc9 h3{color:var(--dim);} .fc9 .fbadge{background:rgba(255,255,255,.07);color:var(--dim);}

/* MNEMO */
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,330px),1fr));gap:22px;}
.mcard{background:var(--surf);border-radius:20px;border:1px solid var(--bord);overflow:hidden;transition:transform .2s,box-shadow .2s;}
.mcard:hover{transform:translateY(-4px);box-shadow:0 20px 60px rgba(0,0,0,.45);}
.mcard-stripe{height:5px;width:100%;}
.mcard-inner{padding:22px;}
.mcard-head{display:flex;align-items:center;gap:14px;margin-bottom:14px;}
.mcard-icon{font-size:30px;width:54px;height:54px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.mcard-tag{font-family:var(--fm);font-size:9px;letter-spacing:3px;text-transform:uppercase;padding:3px 10px;border-radius:20px;display:inline-block;margin-bottom:6px;font-weight:700;}
.mcard-title{font-size:clamp(16px,2.5vw,20px);font-weight:800;line-height:1.1;}
.mcard-desc{
  font-family:var(--fm);font-size:clamp(12px,1.8vw,13px);
  color:var(--tx);line-height:1.9;margin-bottom:16px;
  padding:14px 16px;background:rgba(255,255,255,.03);border-radius:10px;
}
.mcard-desc b{font-weight:700;}
.mcard-ex{border-radius:12px;padding:14px 16px;}
.ex-title{font-family:var(--fm);font-size:9px;letter-spacing:3px;text-transform:uppercase;opacity:.55;margin-bottom:10px;}
.ex-line{font-family:var(--fm);font-size:clamp(11px,1.8vw,13px);font-weight:700;line-height:2.1;display:flex;align-items:baseline;gap:8px;}
.ex-arrow{opacity:.4;flex-shrink:0;}

/* colour variants */
.m-orange .mcard-stripe{background:var(--c1);} .m-orange .mcard-icon{background:rgba(255,107,53,.15);} .m-orange .mcard-tag{background:rgba(255,107,53,.15);color:var(--c1);} .m-orange .mcard-title{color:var(--c1);} .m-orange .mcard-ex{background:rgba(255,107,53,.07);color:var(--c1);}
.m-green .mcard-stripe{background:var(--c3);} .m-green .mcard-icon{background:rgba(0,229,160,.15);} .m-green .mcard-tag{background:rgba(0,229,160,.15);color:var(--c3);} .m-green .mcard-title{color:var(--c3);} .m-green .mcard-ex{background:rgba(0,229,160,.07);color:var(--c3);}
.m-yellow .mcard-stripe{background:var(--c4);} .m-yellow .mcard-icon{background:rgba(255,214,0,.15);} .m-yellow .mcard-tag{background:rgba(255,214,0,.15);color:var(--c4);} .m-yellow .mcard-title{color:var(--c4);} .m-yellow .mcard-ex{background:rgba(255,214,0,.07);color:var(--c4);}
.m-purple .mcard-stripe{background:var(--c2);} .m-purple .mcard-icon{background:rgba(124,77,255,.15);} .m-purple .mcard-tag{background:rgba(124,77,255,.15);color:var(--c2);} .m-purple .mcard-title{color:var(--c2);} .m-purple .mcard-ex{background:rgba(124,77,255,.07);color:var(--c2);}
.m-pink .mcard-stripe{background:var(--c5);} .m-pink .mcard-icon{background:rgba(255,64,129,.15);} .m-pink .mcard-tag{background:rgba(255,64,129,.15);color:var(--c5);} .m-pink .mcard-title{color:var(--c5);} .m-pink .mcard-ex{background:rgba(255,64,129,.07);color:var(--c5);}
.m-blue .mcard-stripe{background:var(--c6);} .m-blue .mcard-icon{background:rgba(0,180,216,.15);} .m-blue .mcard-tag{background:rgba(0,180,216,.15);color:var(--c6);} .m-blue .mcard-title{color:var(--c6);} .m-blue .mcard-ex{background:rgba(0,180,216,.07);color:var(--c6);}
.m-lime .mcard-stripe{background:var(--c8);} .m-lime .mcard-icon{background:rgba(181,232,83,.15);} .m-lime .mcard-tag{background:rgba(181,232,83,.15);color:var(--c8);} .m-lime .mcard-title{color:var(--c8);} .m-lime .mcard-ex{background:rgba(181,232,83,.07);color:var(--c8);}
.m-red .mcard-stripe{background:var(--c7);} .m-red .mcard-icon{background:rgba(247,37,133,.15);} .m-red .mcard-tag{background:rgba(247,37,133,.15);color:var(--c7);} .m-red .mcard-title{color:var(--c7);} .m-red .mcard-ex{background:rgba(247,37,133,.07);color:var(--c7);}

/* TABLE */
.tcontrols{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;}
.sinp{flex:1;min-width:180px;padding:11px 14px;background:var(--surf);border:1px solid var(--bord);border-radius:10px;color:var(--tx);font-family:var(--fm);font-size:12px;outline:none;}
.sinp:focus{border-color:var(--c2);} .sinp::placeholder{color:var(--dim);}
.fsel{padding:11px 12px;background:var(--surf);border:1px solid var(--bord);border-radius:10px;color:var(--tx);font-family:var(--fm);font-size:11px;outline:none;cursor:pointer;}
.fsel option{background:var(--surf);}
.twrap{overflow-x:auto;background:var(--surf);border:1px solid var(--bord);border-radius:16px;}
.vtbl{width:100%;border-collapse:collapse;font-family:var(--fm);font-size:12px;}
.vtbl th{text-align:left;padding:12px 14px;color:var(--dim);font-size:10px;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid var(--bord);}
.vtbl td{padding:10px 14px;border-bottom:1px solid rgba(37,37,56,.5);vertical-align:middle;}
.vtbl tr:hover td{background:var(--surf2);}
.c1t{font-weight:700;} .c2t,.c3t{color:var(--dim);} .c4t{color:var(--dim);font-style:italic;font-size:10px;}
.vtag{display:inline-block;padding:3px 8px;border-radius:6px;font-size:10px;font-weight:700;letter-spacing:1px;}

/* QUIZ */
.qwrap{max-width:660px;margin:0 auto;}
.qsettings{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:22px;justify-content:center;}
.chip{padding:8px 16px;background:var(--surf);border:1px solid var(--bord);border-radius:20px;font-family:var(--fm);font-size:11px;color:var(--dim);cursor:pointer;transition:all .2s;letter-spacing:1px;}
.chip:hover{border-color:var(--dim);color:var(--tx);}
.chip.active{background:var(--c2);border-color:var(--c2);color:#fff;}
.qtop{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:10px;}
.qscore{font-family:var(--fm);font-size:12px;color:var(--dim);}
.qscore span{color:var(--c3);font-weight:700;}
.btn-sm{padding:10px 20px;background:var(--surf2);border:1px solid var(--bord);border-radius:10px;color:var(--dim);font-family:var(--fh);font-weight:700;font-size:13px;cursor:pointer;transition:all .2s;}
.btn-sm:hover{color:var(--tx);border-color:var(--dim);}
.pbar{height:4px;background:var(--surf2);border-radius:4px;margin-bottom:32px;overflow:hidden;}
.pfill{height:100%;background:linear-gradient(90deg,var(--c2),var(--c3));border-radius:4px;transition:width .4s ease;}
.qcard{background:var(--surf);border:1px solid var(--bord);border-radius:20px;padding:clamp(22px,5vw,44px);text-align:center;min-height:280px;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.qlabel{font-family:var(--fm);font-size:10px;letter-spacing:3px;color:var(--dim);margin-bottom:18px;text-transform:uppercase;}
.qverb{font-size:clamp(34px,8vw,60px);font-weight:800;color:var(--c1);letter-spacing:-2px;margin-bottom:10px;}
.qfr{font-family:var(--fm);font-size:12px;color:var(--dim);margin-bottom:30px;}
.qinputs{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;width:100%;}
.qinp{flex:1;min-width:130px;padding:14px 16px;background:var(--bg);border:2px solid var(--bord);border-radius:11px;color:var(--tx);font-family:var(--fm);font-size:14px;text-align:center;outline:none;transition:border-color .2s;}
.qinp:focus{border-color:var(--c2);}
.qinp.ok{border-color:var(--c3);background:rgba(0,229,160,.05);color:var(--c3);}
.qinp.ko{border-color:var(--c5);background:rgba(255,64,129,.05);color:var(--c5);}
.qactions{display:flex;gap:10px;margin-top:24px;flex-wrap:wrap;justify-content:center;}
.btn-pri{padding:13px 28px;background:var(--c2);border:none;border-radius:11px;color:#fff;font-family:var(--fh);font-weight:700;font-size:14px;cursor:pointer;transition:all .2s;}
.btn-pri:hover{background:#9965ff;transform:translateY(-1px);}
.btn-sec{padding:13px 24px;background:var(--surf2);border:1px solid var(--bord);border-radius:11px;color:var(--dim);font-family:var(--fh);font-weight:700;font-size:14px;cursor:pointer;}
.btn-sec:hover{color:var(--tx);}
.qfeedback{margin-top:18px;font-family:var(--fm);font-size:13px;min-height:22px;display:flex;gap:20px;flex-wrap:wrap;justify-content:center;}
.qfb-item{color:var(--dim);}
.qfb-item strong{color:var(--c3);}
.qresult{text-align:center;padding:40px 20px;}
.qresult .bscore{font-size:clamp(60px,12vw,88px);font-weight:800;line-height:1;margin-bottom:10px;}
.qresult p{font-family:var(--fm);font-size:13px;color:var(--dim);margin-bottom:24px;}

/* PLAN */
.plangrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,290px),1fr));gap:18px;}
.pcard{background:var(--surf);border:1px solid var(--bord);border-radius:18px;padding:26px;position:relative;overflow:hidden;}
.pcard::before{content:attr(data-d);position:absolute;top:-8px;right:16px;font-size:72px;font-weight:800;color:rgba(255,255,255,.03);line-height:1;pointer-events:none;}
.pcard-day{font-family:var(--fm);font-size:10px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;margin-bottom:8px;}
.pcard h3{font-size:18px;font-weight:800;color:var(--c2);margin-bottom:14px;}
.pcard ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
.pcard ul li{font-family:var(--fm);font-size:12px;color:var(--dim);display:flex;align-items:flex-start;gap:10px;line-height:1.6;padding-bottom:8px;border-bottom:1px solid var(--bord);}
.pcard ul li:last-child{border-bottom:none;padding-bottom:0;}
.pcard ul li::before{content:'→';color:var(--c3);flex-shrink:0;}

/* MOBILE */
@media(max-width:600px){
  .wrap{padding:0 10px 50px;}
  .tabs{border-radius:12px;padding:4px;}
  .tab-btn{min-width:80px;padding:9px 8px;font-size:11px;border-radius:8px;}
  .fcard{padding:16px;}
  .vrow{font-size:10px;padding:6px 8px;}
  .mcard-inner{padding:16px;}
  .mcard-desc{font-size:12px;padding:12px;}
  .mcard-ex{padding:12px;}
  .vtbl .c4t{display:none;}
  .qcard{padding:18px 14px;border-radius:16px;}
  .qverb{font-size:clamp(28px,9vw,44px);}
  .qinp{font-size:13px;padding:12px 10px;}
  .pcard{padding:18px;}
}
</style>
</head>
<body>
<div class="wrap">

<header>
  <div class="eyebrow">🇬🇧 Méthode accélérée · 140 verbes</div>
  <h1>Verbes<br>Irréguliers</h1>
  <p>80 + 60 verbes du fichier — organisés en <strong style="color:var(--tx)">9 familles de sons</strong> pour une mémorisation rapide et durable.</p>
</header>

<div class="formula">
  <div class="step"><span class="sv">Infinitif</span><span class="sl">base</span></div>
  <span class="arrow">→</span>
  <div class="step"><span class="sv">Prétérit</span><span class="sl">passé simple</span></div>
  <span class="arrow">→</span>
  <div class="step"><span class="sv">Participe Passé</span><span class="sl">have + …</span></div>
</div>

<div class="tabs">
  <button class="tab-btn active" onclick="showTab('families',this)">🧩 Familles</button>
  <button class="tab-btn" onclick="showTab('quiz',this)">⚡ Quiz</button>
  <button class="tab-btn" onclick="showTab('table',this)">📋 Tableau</button>
  <button class="tab-btn" onclick="showTab('mnemo',this)">🧠 Mémo</button>
  <button class="tab-btn" onclick="showTab('plan',this)">📅 Plan</button>
</div>

<!-- FAMILIES -->
<div id="tab-families" class="panel active">
  <div class="fgrid" id="familiesGrid"></div>
</div>

<!-- QUIZ -->
<div id="tab-quiz" class="panel">
  <div class="qwrap">
    <div class="qsettings" id="qSettings">
      <div class="chip active" onclick="setQFam('all',this)">Tous</div>
      <div class="chip" onclick="setQFam('iau',this)">🎵 I-A-U</div>
      <div class="chip" onclick="setQFam('same',this)">✂️ Tout pareil</div>
      <div class="chip" onclick="setQFam('dt',this)">🔄 D→T</div>
      <div class="chip" onclick="setQFam('vowel',this)">🌊 Voyelle</div>
      <div class="chip" onclick="setQFam('en',this)">📝 -en/-n</div>
      <div class="chip" onclick="setQFam('ough',this)">💥 -ought</div>
      <div class="chip" onclick="setQFam('ewn',this)">💨 ew→own</div>
    </div>
    <div class="qtop">
      <div class="qscore">Score : <span id="qScoreDisp">0</span> / <span id="qTotalDisp">0</span></div>
      <button class="btn-sm" onclick="resetQuiz()">↺ Recommencer</button>
    </div>
    <div class="pbar"><div class="pfill" id="pFill" style="width:0%"></div></div>
    <div id="qContent"></div>
  </div>
</div>

<!-- TABLE -->
<div id="tab-table" class="panel">
  <div class="tcontrols">
    <input class="sinp" id="sinp" placeholder="Chercher un verbe…" oninput="filterTable()">
    <select class="fsel" id="fsel" onchange="filterTable()">
      <option value="all">Toutes familles</option>
      <option value="iau">🎵 I-A-U</option>
      <option value="same">✂️ Tout pareil</option>
      <option value="dt">🔄 D→T</option>
      <option value="vowel">🌊 Voyelle</option>
      <option value="en">📝 -en/-n</option>
