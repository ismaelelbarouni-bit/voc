   ex:["Miroir salle de bain → 3 verbes rebelles","Frigo → 3 verbes rebelles","Écran d'ordinateur → 4 verbes rebelles","= Lu et relu chaque jour sans s'en rendre compte"]},
  {col:"m-purple",icon:"⚡",tag:"PRIORITÉ ABSOLUE",title:"Les 50 verbes les plus fréquents d'abord",
   desc:"Inutile d'apprendre <em>to strive</em> si tu hésites encore sur <em>to get</em>. <b>Priorise les verbes du quotidien</b> — ils couvrent 90% de ce que tu entendras et liras en anglais réel. Maîtrise-les avant d'aller plus loin.",
   ex:["Priorité 1 : be, have, do, go, get, say","Priorité 2 : make, know, take, come, see","Priorité 3 : think, look, want, give, use","Priorité 4 : find, tell, become, leave, put"]},
];

// ═══════════════ RENDER ═══════════════
function renderFamilies(){
  document.getElementById('familiesGrid').innerHTML=FAMILIES.map(f=>{
    const vs=VERBS.filter(v=>v.f===f.id);
    const rows=vs.slice(0,7).map(v=>`<div class="vrow"><span class="v1">${v.i.replace('to ','')}</span><span class="v2">${v.p}</span><span class="v3">${v.pp}</span><span class="vmean">${v.fr}</span></div>`).join('');
    const more=vs.length>7?`<div class="more">+ ${vs.length-7} autres dans le Tableau</div>`:'';
    return `<div class="fcard ${f.cls}"><span class="fbadge">${f.badge}</span><h3>${f.name}</h3><div class="fsub">${f.sub}</div><div class="vlist">${rows}${more}</div></div>`;
  }).join('');
}

function renderTable(vs){
  document.getElementById('vtbody').innerHTML=vs.map((v,i)=>{
    const fc=FAM_C[v.f]||FAM_C.other;
    return `<tr><td style="color:var(--dim);font-size:10px;font-family:var(--fm)">${i+1}</td><td class="c1t">${v.i}</td><td class="c2t">${v.p}</td><td class="c3t">${v.pp}</td><td class="c4t">${v.fr}</td><td><span class="vtag" style="background:${fc.bg};color:${fc.col}">${FAM_L[v.f]||'?'}</span></td></tr>`;
  }).join('');
}
function filterTable(){
  const q=document.getElementById('sinp').value.toLowerCase();
  const f=document.getElementById('fsel').value;
  let l=VERBS;
  if(f!=='all') l=l.filter(v=>v.f===f);
  if(q) l=l.filter(v=>v.i.includes(q)||v.p.includes(q)||v.pp.includes(q)||v.fr.toLowerCase().includes(q));
  renderTable(l);
}

function renderMnemos(){
  document.getElementById('mnemoGrid').innerHTML=MNEMOS.map(m=>`
    <div class="mcard ${m.col}">
      <div class="mcard-stripe"></div>
      <div class="mcard-inner">
        <div class="mcard-head">
          <div class="mcard-icon">${m.icon}</div>
          <div><div class="mcard-tag">${m.tag}</div><div class="mcard-title">${m.title}</div></div>
        </div>
        <div class="mcard-desc">${m.desc}</div>
        <div class="mcard-ex">
          <div class="ex-title">Exemples concrets</div>
          ${m.ex.map(e=>`<div class="ex-line"><span class="ex-arrow">→</span><span>${e}</span></div>`).join('')}
        </div>
      </div>
    </div>`).join('');
}

// ═══════════════ QUIZ ═══════════════
let qV=[],qIdx=0,qScore=0,qTotal=0,qFam='all';
function setQFam(f,el){qFam=f;document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));el.classList.add('active');resetQuiz();}
function resetQuiz(){
  qScore=0;qTotal=0;qIdx=0;
  qV=(qFam==='all'?[...VERBS]:VERBS.filter(v=>v.f===qFam)).sort(()=>Math.random()-.5);
  document.getElementById('qScoreDisp').textContent=0;
  document.getElementById('qTotalDisp').textContent=0;
  document.getElementById('pFill').style.width='0%';
  renderQ();
}
function renderQ(){
  const c=document.getElementById('qContent');
  if(qIdx>=qV.length){
    const pct=qTotal>0?Math.round(qScore/qTotal*100):0;
    const col=pct>=80?'var(--c3)':pct>=50?'var(--c4)':'var(--c5)';
    c.innerHTML=`<div class="qresult"><div class="bscore" style="color:${col}">${pct}%</div><p>${qScore} / ${qTotal} points corrects</p><div class="qactions"><button class="btn-pri" onclick="resetQuiz()">↺ Recommencer</button></div></div>`;
    return;
  }
  const v=qV[qIdx];
  c.innerHTML=`<div class="qcard"><div class="qlabel">PRÉTÉRIT + PARTICIPE PASSÉ</div><div class="qverb">${v.i}</div><div class="qfr">${v.fr}</div><div class="qinputs"><input class="qinp" id="qi1" placeholder="Prétérit…" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')checkQ()"><input class="qinp" id="qi2" placeholder="Participe passé…" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')checkQ()"></div><div class="qactions"><button class="btn-pri" onclick="checkQ()">Vérifier ✓</button><button class="btn-sec" onclick="skipQ()">Passer →</button></div><div class="qfeedback" id="qfb"></div></div>`;
  setTimeout(()=>document.getElementById('qi1')?.focus(),60);
}
function norm(s){return s.trim().toLowerCase().replace(/\s*\(.*?\)/g,'').replace(/\s+/g,' ').split('/')[0].trim();}
function checkQ(){
  const v=qV[qIdx];
  const i1=document.getElementById('qi1'),i2=document.getElementById('qi2');
  if(!i1||!i2)return;
  const ok1=v.p.split('/').map(s=>norm(s)).includes(norm(i1.value));
  const ok2=v.pp.split('/').map(s=>norm(s)).includes(norm(i2.value));
  i1.classList.add(ok1?'ok':'ko');i2.classList.add(ok2?'ok':'ko');
  qScore+=(ok1?1:0)+(ok2?1:0);qTotal+=2;
  document.getElementById('qfb').innerHTML=`<span class="qfb-item">Prétérit : <strong>${v.p}</strong></span><span class="qfb-item">Participe : <strong>${v.pp}</strong></span>`;
  document.getElementById('qScoreDisp').textContent=qScore;
  document.getElementById('qTotalDisp').textContent=qTotal;
  document.getElementById('pFill').style.width=Math.round(qIdx/qV.length*100)+'%';
  setTimeout(()=>{qIdx++;renderQ();},1600);
}
function skipQ(){
  const v=qV[qIdx];
  document.getElementById('qfb').innerHTML=`<span class="qfb-item">Prétérit : <strong>${v.p}</strong></span><span class="qfb-item">Participe : <strong>${v.pp}</strong></span>`;
  qTotal+=2;document.getElementById('qTotalDisp').textContent=qTotal;
  setTimeout(()=>{qIdx++;renderQ();},1400);
}

// ═══════════════ TABS ═══════════════
function showTab(name,el){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  el.classList.add('active');
  if(name==='table') filterTable();
  if(name==='quiz'&&qV.length===0) resetQuiz();
}

// ═══════════════ INIT ═══════════════
renderFamilies();
renderTable(VERBS);
renderMnemos();
</script>
